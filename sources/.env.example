# ── Anthropic API Key ─────────────────────────────────────────────────────────
# Used as the primary fallback parser when all Gemini keys fail or are rate-limited.
# Also used by: modules/data_prep/nbc_extractor.py
# Model:   claude-sonnet-4-5
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Gemini API Keys (product / project flows only) ────────────────────────────
# Add as many keys as you have accounts (GEMINI_API_KEY_1, _2, _3, ...)
# The key rotator auto-discovers them at startup for round-robin rate-limit mitigation.
GEMINI_API_KEY_1=your-first-api-key
GEMINI_API_KEY_2=your-second-api-key
GEMINI_API_KEY_3=your-third-api-key

# Legacy single-key fallback (used if no numbered keys found)
GEMINI_API_KEY=your-api-key

# Dedicated key for Gemini Vision (multimodal image analysis)
# Separate from the rotation pool so vision calls don't consume text-parsing quota
GEMINI_IMAGE_API_KEY=your-image-analysis-api-key
